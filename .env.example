# Optional model/API configuration for local experiments.
# Core tests must not require these.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Defaults when unset:
# LABFLOW_MODEL_PROVIDER: deterministic
# LABFLOW_OPENROUTER_MODEL: nvidia/nemotron-3-ultra-550b-a55b:free
# OPENROUTER_BASE_URL: https://openrouter.ai/api/v1
# OPENROUTER_APP_TITLE: LabFlow AI Studio
# OPENROUTER_TIMEOUT_SECONDS: 30
# OPENROUTER_MAX_RETRIES: 1
# OPENROUTER_RETRY_BACKOFF_SECONDS: 1
# OPENROUTER_RETRY_BACKOFF_MULTIPLIER: 2
# OPENROUTER_RETRY_MAX_BACKOFF_SECONDS: 8
# OPENROUTER_ENABLE_METADATA: false
# LABFLOW_OPENROUTER_FALLBACK_MODELS: unset
# LABFLOW_OPENROUTER_RESPONSE_FORMAT: json_object
# LABFLOW_MODEL_EVAL_MAX_CASE_SECONDS: unset
LABFLOW_MODEL_PROVIDER=
LABFLOW_OPENROUTER_MODEL=
LABFLOW_OPENROUTER_FALLBACK_MODELS=
LABFLOW_OPENROUTER_RESPONSE_FORMAT=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
OPENROUTER_TIMEOUT_SECONDS=
OPENROUTER_MAX_RETRIES=
OPENROUTER_RETRY_BACKOFF_SECONDS=
OPENROUTER_RETRY_BACKOFF_MULTIPLIER=
OPENROUTER_RETRY_MAX_BACKOFF_SECONDS=
OPENROUTER_ENABLE_METADATA=
LABFLOW_MODEL_EVAL_MAX_CASE_SECONDS=

# Local API default when unset: http://localhost:8000
LABFLOW_API_URL=
